# Digital Frame configuration. Copied to ~/.config/digital-frame/frame.env by
# install.sh; edit the values there for your device.

# Absolute path to the folder of photos to display (no ~ / $HOME expansion here).
FRAME_DIR=/home/CHANGE_ME/Pictures

# Hyprland output name of the frame monitor. Find it with: hyprctl monitors
FRAME_MONITOR=HDMI-A-1

# Extra flags passed to frame.py (see the project README for the full list).
FRAME_ARGS=--interval 8 -r

# Server bind port and the URL the kiosk browser opens.
FRAME_PORT=8080
FRAME_URL=http://localhost:8080

# Window class assigned to the kiosk browser; must match the Hyprland rule.
FRAME_CLASS=digital-frame

# Absolute path to this repository checkout (auto-filled by install.sh).
FRAME_REPO=@REPO@
